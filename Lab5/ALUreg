#!/usr/bin/perl -w
use strict;

# -------------------- GENERATED REGISTER ADDRESSES --------------------
# From generated reg_defines for pipeline block
my $PIPE_SW_REQ_CMD_REG       = 0x2000300;
my $PIPE_SW_REQ_ADDR_REG      = 0x2000304;
my $PIPE_SW_REQ_DATA_LO_REG   = 0x2000308;
my $PIPE_SW_REQ_DATA_HI_REG   = 0x200030c;
my $PIPE_SW_REQ_VAL_REG       = 0x2000310;
my $PIPE_SW_RESP_RDY_REG      = 0x2000314;
my $PIPE_SW_CPU_START_REG     = 0x2000318;
my $PIPE_SW_ILA_DEBUG_SEL_REG = 0x200031c;

my $PIPE_HW_REQ_RDY_REG       = 0x2000320;
my $PIPE_HW_RESP_CMD_REG      = 0x2000324;
my $PIPE_HW_RESP_ADDR_REG     = 0x2000328;
my $PIPE_HW_RESP_DATA_LO_REG  = 0x200032c;
my $PIPE_HW_RESP_DATA_HI_REG  = 0x2000330;
my $PIPE_HW_RESP_VAL_REG      = 0x2000334;
my $PIPE_HW_ILA_DEBUG_LO_REG  = 0x2000338;
my $PIPE_HW_ILA_DEBUG_HI_REG  = 0x200033c;
# ---------------------------------------------------------------------

# Run regwrite/regread (NetFPGA command-line utilities). Adjust path if needed.
sub regwrite {
   my( $addr, $value ) = @_;
   my $cmd = sprintf( "regwrite 0x%08x 0x%08x", $addr, $value );
   my $result = `$cmd 2>&1`;
   return $result;
}

sub regread {
   my( $addr ) = @_;
   my $cmd = sprintf( "regread 0x%08x", $addr );
   my @out = `$cmd 2>&1`;

   foreach my $line (@out) {
      # verbose format: Reg 0xADDR (DEC): 0xVALUE (DEC)
      if ( $line =~ m/Reg\s+(0x[0-9a-fA-F]+)\s+\(\d+\):\s+(0x[0-9a-fA-F]+)\s+\(\d+\)/ ) {
         return $3;
      }
      # simple form: plain hex on a line
      if ( $line =~ m/^\s*(0x[0-9a-fA-F]+)\s*$/ ) {
         return $1;
      }
   }
   return ($out[0] // "");
}

# ----------------- Helpers for pipeline block -----------------

# Write a full 64-bit request data (req_data_hi/lo), set req_addr, req_cmd (bit 0) and req_val (bit 0)
# Usage: write_request($cmd_bit, $addr32, $data64_hex, $val_bit)
sub write_request {
   my ($cmd_bit, $addr32, $data64, $val_bit) = @_;
   my $data = parse_num($data64);
   my $hi = ($data >> 32) & 0xFFFFFFFF;
   my $lo = $data & 0xFFFFFFFF;

   regwrite($PIPE_SW_REQ_DATA_HI_REG, $hi);
   regwrite($PIPE_SW_REQ_DATA_LO_REG, $lo);

   # req_addr is 32-bit (already)
   regwrite($PIPE_SW_REQ_ADDR_REG, parse_num($addr32));

   # write val and cmd bits (they are single-bit fields but registers are 32-bit)
   regwrite($PIPE_SW_REQ_VAL_REG, int($val_bit) & 1);
   regwrite($PIPE_SW_REQ_CMD_REG, int($cmd_bit) & 1);
}

# Simple setters
sub set_req_cmd { my $b = shift; regwrite($PIPE_SW_REQ_CMD_REG, int($b) & 1); }
sub set_req_addr { my $a = shift; regwrite($PIPE_SW_REQ_ADDR_REG, parse_num($a)); }
sub set_req_data { my $d = shift; my $v = parse_num($d); regwrite($PIPE_SW_REQ_DATA_HI_REG, ($v>>32)&0xFFFFFFFF); regwrite($PIPE_SW_REQ_DATA_LO_REG, $v & 0xFFFFFFFF); }
sub set_req_val { my $b = shift; regwrite($PIPE_SW_REQ_VAL_REG, int($b) & 1); }
sub set_cpu_start { my $b = shift; regwrite($PIPE_SW_CPU_START_REG, int($b) & 1); }
sub set_ila_debug_sel { my $v = shift; regwrite($PIPE_SW_ILA_DEBUG_SEL_REG, int($v) & 0x1F); }

# Read hardware outputs: returns a hashref with parsed fields
sub read_hw {
   my $req_rdy = regread($PIPE_HW_REQ_RDY_REG);
   my $resp_cmd = regread($PIPE_HW_RESP_CMD_REG);
   my $resp_addr = regread($PIPE_HW_RESP_ADDR_REG);
   my $resp_lo = regread($PIPE_HW_RESP_DATA_LO_REG);
   my $resp_hi = regread($PIPE_HW_RESP_DATA_HI_REG);
   my $resp_val = regread($PIPE_HW_RESP_VAL_REG);
   my $ila_lo = regread($PIPE_HW_ILA_DEBUG_LO_REG);
   my $ila_hi = regread($PIPE_HW_ILA_DEBUG_HI_REG);

   # parse numeric values for composing 64-bit fields
   my $r_hi = defined $resp_hi ? parse_num($resp_hi) : 0;
   my $r_lo = defined $resp_lo ? parse_num($resp_lo) : 0;
   my $resp_64 = sprintf("0x%08x%08x", $r_hi, $r_lo);

   my $ila_hi_n = defined $ila_hi ? parse_num($ila_hi) : 0;
   my $ila_lo_n = defined $ila_lo ? parse_num($ila_lo) : 0;
   my $ila_64 = sprintf("0x%08x%08x", $ila_hi_n, $ila_lo_n);

   return {
      req_rdy => ($req_rdy // ""),
      resp_cmd => ($resp_cmd // ""),
      resp_addr => ($resp_addr // ""),
      resp_val => ($resp_val // ""),
      resp_data_64 => $resp_64,
      ila_debug_64 => $ila_64
   };
}

# Print all registers (raw and composed)
sub dump_allregs {
   my $r = read_hw();
   print "Pipeline registers (raw 32-bit values):\n";
   print sprintf("  REQ_CMD (0x%08x): %s\n", $PIPE_SW_REQ_CMD_REG, regread($PIPE_SW_REQ_CMD_REG));
   print sprintf("  REQ_ADDR(0x%08x): %s\n", $PIPE_SW_REQ_ADDR_REG, regread($PIPE_SW_REQ_ADDR_REG));
   print sprintf("  REQ_DATA_LO(0x%08x): %s\n", $PIPE_SW_REQ_DATA_LO_REG, regread($PIPE_SW_REQ_DATA_LO_REG));
   print sprintf("  REQ_DATA_HI(0x%08x): %s\n", $PIPE_SW_REQ_DATA_HI_REG, regread($PIPE_SW_REQ_DATA_HI_REG));
   print sprintf("  REQ_VAL (0x%08x): %s\n", $PIPE_SW_REQ_VAL_REG, regread($PIPE_SW_REQ_VAL_REG));
   print sprintf("  RESP_RDY(0x%08x): %s\n", $PIPE_SW_RESP_RDY_REG, regread($PIPE_SW_RESP_RDY_REG));
   print sprintf("  CPU_START(0x%08x): %s\n", $PIPE_SW_CPU_START_REG, regread($PIPE_SW_CPU_START_REG));
   print sprintf("  ILA_SEL (0x%08x): %s\n", $PIPE_SW_ILA_DEBUG_SEL_REG, regread($PIPE_SW_ILA_DEBUG_SEL_REG));

   print sprintf("  HW_REQ_RDY (0x%08x): %s\n", $PIPE_HW_REQ_RDY_REG, regread($PIPE_HW_REQ_RDY_REG));
   print sprintf("  HW_RESP_CMD(0x%08x): %s\n", $PIPE_HW_RESP_CMD_REG, regread($PIPE_HW_RESP_CMD_REG));
   print sprintf("  HW_RESP_ADDR(0x%08x): %s\n", $PIPE_HW_RESP_ADDR_REG, regread($PIPE_HW_RESP_ADDR_REG));
   print sprintf("  HW_RESP_DATA_LO(0x%08x): %s\n", $PIPE_HW_RESP_DATA_LO_REG, regread($PIPE_HW_RESP_DATA_LO_REG));
   print sprintf("  HW_RESP_DATA_HI(0x%08x): %s\n", $PIPE_HW_RESP_DATA_HI_REG, regread($PIPE_HW_RESP_DATA_HI_REG));
   print sprintf("  HW_RESP_VAL (0x%08x): %s\n", $PIPE_HW_RESP_VAL_REG, regread($PIPE_HW_RESP_VAL_REG));
   print sprintf("  ILA_DEBUG_LO(0x%08x): %s\n", $PIPE_HW_ILA_DEBUG_LO_REG, regread($PIPE_HW_ILA_DEBUG_LO_REG));
   print sprintf("  ILA_DEBUG_HI(0x%08x): %s\n", $PIPE_HW_ILA_DEBUG_HI_REG, regread($PIPE_HW_ILA_DEBUG_HI_REG));

   print "Composed hardware values:\n";
   print "  resp_data_64 = " . $r->{resp_data_64} . "\n";
   print "  ila_debug_64 = " . $r->{ila_debug_64} . "\n";
}

# parse numbers (0xHEX or decimal or HEX)
sub parse_num {
   my ($s) = @_;
   return 0 unless defined $s;
   $s =~ s/^0x//i;
   if ($s =~ /^[0-9a-fA-F]+$/) { return hex($s); }
   return int($s);
}

# ------------------- CLI ---------------------
sub usage {
   print <<"USAGE";
Usage: pipeline_reg_tool.pl <cmd> [args]

Commands:
  write_request <cmd_bit> <addr32> <data64> <val_bit>
      - write full request (data split to hi/lo) and small control bits
        Example: write_request 1 0x10 0x0123456789ABCDEF 1

  set_req_cmd <0|1>
  set_req_addr <32-bit addr or hex>
  set_req_data <64-bit hex>
  set_req_val <0|1>
  set_cpu_start <0|1>
  set_ila_debug_sel <value 0..31>

  read_hw
      - read and print hardware outputs

  dump_allregs
      - print raw 32-bit SW/HW registers and composed 64-bit HW fields

  help

Notes:
 - The script uses command-line 'regread' and 'regwrite' programs available in the NetFPGA environment.
 - The block is pipelined/clocked: you may need to wait a few cycles after writes before responses appear.
USAGE
}

my $n = @ARGV;
if ($n < 1) { usage(); exit(1) }
my $cmd = shift @ARGV;

if ($cmd eq "write_request") {
   if (@ARGV < 4) { usage(); exit(1) }
   write_request(@ARGV[0..3]);
   print "Wrote request cmd=$ARGV[0] addr=$ARGV[1] data=$ARGV[2] val=$ARGV[3]\n";
}
elsif ($cmd eq "set_req_cmd") {
   set_req_cmd($ARGV[0]); print "Set req_cmd=$ARGV[0]\n";
}
elsif ($cmd eq "set_req_addr") {
   set_req_addr($ARGV[0]); print "Set req_addr=$ARGV[0]\n";
}
elsif ($cmd eq "set_req_data") {
   set_req_data($ARGV[0]); print "Set req_data=$ARGV[0]\n";
}
elsif ($cmd eq "set_req_val") {
   set_req_val($ARGV[0]); print "Set req_val=$ARGV[0]\n";
}
elsif ($cmd eq "set_cpu_start") {
   set_cpu_start($ARGV[0]); print "Set cpu_start=$ARGV[0]\n";
}
elsif ($cmd eq "set_ila_debug_sel") {
   set_ila_debug_sel($ARGV[0]); print "Set ila_debug_sel=$ARGV[0]\n";
}
elsif ($cmd eq "read_hw") {
   my $r = read_hw();
   print "HW read:\n";
   print "  req_rdy = " . $r->{req_rdy} . "\n";
   print "  resp_cmd = " . $r->{resp_cmd} . "\n";
   print "  resp_addr = " . $r->{resp_addr} . "\n";
   print "  resp_val = " . $r->{resp_val} . "\n";
   print "  resp_data_64 = " . $r->{resp_data_64} . "\n";
   print "  ila_debug_64 = " . $r->{ila_debug_64} . "\n";
}
elsif ($cmd eq "dump_allregs") {
   dump_allregs();
}
elsif ($cmd eq "help") {
   usage();
}
else {
   print "Unknown cmd: $cmd\n";
   usage();
   exit(1);
}
